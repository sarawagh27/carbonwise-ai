{
  "name": "carbonwise-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered sustainability platform that transforms receipts, activities, and daily habits into actionable carbon footprint insights using Google Gemini.",
  "author": "Sara Wagh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarawagh27/carbonwise-ai.git"
  },
  "homepage": "https://carbonwise-ai-five.vercel.app",
  "keywords": [
    "react",
    "typescript",
    "firebase",
    "gemini-ai",
    "sustainability",
    "carbon-footprint",
    "vercel",
    "tailwindcss",
    "hackathon",
    "portfolio-project"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.20.0",
    "esbuild": "^0.25.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
