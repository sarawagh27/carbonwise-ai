# ============================================================
# CarbonWise AI — Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in your credentials:
#   cp .env.example .env.local
#
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Google Gemini AI
# ------------------------------------------------------------
# API key for Google Gemini AI (server-side only).
# Obtain from: https://aistudio.google.com/apikey
# Used by the Express backend for receipt scanning, activity
# analysis, sustainability coaching, and report generation.
GEMINI_API_KEY="your_gemini_api_key_here"

# ------------------------------------------------------------
# Firebase Configuration
# ------------------------------------------------------------
# All values below come from Firebase Console:
#   Project Settings > General > Your Apps > Web App
# These are client-side variables (VITE_ prefix) embedded
# in the frontend bundle at build time.

# Firebase Web API Key
VITE_FIREBASE_API_KEY="your_firebase_api_key"

# Firebase Auth Domain (typically: your-project-id.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID="your-project-id"

# Firebase Storage Bucket (typically: your-project-id.firebasestorage.app)
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"

# Firebase Cloud Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"

# Firebase App ID
VITE_FIREBASE_APP_ID="your_firebase_app_id"

# ------------------------------------------------------------
# Firebase Firestore (Optional)
# ------------------------------------------------------------
# Only set this if using a named Firestore database instead
# of the default "(default)" database. Leave empty otherwise.
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
